{
  "id": "saas-admin",
  "name": "SaaS Admin",
  "description": "A product-grade SaaS/admin starter with auth, RBAC, dashboard, settings, and prototype routes.",
  "stack": {
    "frontend": "Next.js + React + TypeScript + Tailwind CSS",
    "backend": "Spring Boot + Java 21",
    "database": "PostgreSQL",
    "runtime": "Docker Compose"
  },
  "modules": [
    "auth",
    "rbac",
    "audit-log"
  ],
  "dataLayer": "jpa-flyway",
  "variables": {
    "appName": "My Saas",
    "packageName": "my-saas",
    "javaPackage": "com.productflow.app",
    "language": "bilingual",
    "frontendPort": 3000,
    "backendPort": 8080,
    "databasePort": 5432,
    "databaseName": "productflow",
    "packageManager": "npm"
  },
  "postInstall": [
    "Copy .env.example to .env",
    "Run docker compose up --build"
  ]
}
